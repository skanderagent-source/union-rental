NODE_ENV=development
PORT=4001
PUBLIC_API_BASE_URL=http://localhost:4001
FRONTEND_ORIGIN=http://localhost:5174
# Production (VPS .env): https://YOUR_UNION_DOMAIN
# Staging (optional): https://staging.YOUR_UNION_DOMAIN
# Development: http://localhost:5174
# Comma-separate multiple origins only when needed; never use wildcards.

SUPABASE_URL=https://twkqsaupojldddclgpqj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-readonly-access-key-id
R2_SECRET_ACCESS_KEY=your-readonly-secret-access-key
R2_BUCKET=your-shared-r2-bucket
R2_SIGNED_DOWNLOAD_EXPIRES_SECONDS=300

RESEND_API_KEY=
EMAIL_ENABLED=false
EMAIL_FROM="LogiGo <notifications@YOUR_UNION_DOMAIN>"
EMAIL_REPLY_TO=
FAST_RENTAL_APP_URL=http://localhost:5173
# Optional. Auto-detected in development when ../Fast Rental exists.
# FAST_RENTAL_LOCAL_STORAGE_ROOT=/absolute/path/to/Fast Rental/apps/backend/.local-storage

RATE_LIMIT_LEADS_WINDOW_MS=60000
RATE_LIMIT_LEADS_MAX=20
RATE_LIMIT_READS_WINDOW_MS=60000
RATE_LIMIT_READS_MAX=240

# Proxy hops in front of Node (Caddy). Use 0 for direct local access without a proxy.
TRUST_PROXY=1
# Optional comma-separated extra Host values (PUBLIC_API_BASE_URL host is always allowed).
# TRUSTED_HOSTS=api.your-union-domain.com

# Request parsing and server timeouts
JSON_BODY_LIMIT=100kb
HTTP_KEEP_ALIVE_TIMEOUT_MS=65000
HTTP_HEADERS_TIMEOUT_MS=66000
HTTP_REQUEST_TIMEOUT_MS=30000
DB_QUERY_TIMEOUT_MS=15000
SHUTDOWN_GRACE_MS=10000
LOG_LEVEL=info
